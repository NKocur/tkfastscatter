# Rust build output
/target/

# Compiled Python extension (generated by maturin develop)
python/tkfastscatter/*.pyd
python/tkfastscatter/*.so
python/tkfastscatter/*.dylib

# Python packaging artifacts
dist/
*.egg-info/
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# maturin lock / wheel cache
*.whl

# Editor / tooling state
.vscode/
.idea/

# Test and CI caches
.pytest_cache/
.test-cache/
.coverage
htmlcov/

# Claude Code project memory
.claude/

# Temporary build-verification directories (dist_check*, dist_audit*, etc.)
/dist_*/
